#!/usr/bin/env python3
"""continuity-gh — transparent gh/git interceptor.

Wires together modules:
    db.py     — schema, SQLite connection
    runner.py — binary resolution, subprocess delegation
    block.py  — dangerous command blocking (Phase 3)
    parse.py  — structured CI event parsing (Phase 2)

All three phases operate in sequence: block → delegate + log → parse.
Cross-platform: macOS, Linux, Windows.
"""

import json
import os
import sys
import time
from pathlib import Path

# Ensure the install directory is on sys.path so sibling modules resolve.
# When installed via continuity-install, the whole python/ dir is copied.
_install_dir = str(Path(__file__).resolve().parent)
if _install_dir not in sys.path:
    sys.path.insert(0, _install_dir)

from db import ensure_db, SCHEMA
from runner import resolve_binary, run_binary
from block import check_dangerous
import gh
import git

# ── Resolved at module load ────────────────────────────────────────────────

REAL_GH = os.environ.get("CONTINUITY_REAL_GH", resolve_binary("gh"))
REAL_GIT = os.environ.get("CONTINUITY_REAL_GIT", resolve_binary("git"))


def _data_dir() -> Path:
    """Platform-appropriate data directory."""
    if sys.platform == "win32":
        base = os.environ.get("LOCALAPPDATA",
                              os.path.expandvars(r"%USERPROFILE%\AppData\Local"))
        return Path(base) / "continuity"
    xdg = os.environ.get("XDG_DATA_HOME", "")
    if xdg:
        return Path(xdg) / "continuity"
    return Path.home() / ".local" / "share" / "continuity"


def _resolve_db_path() -> Path:
    """Resolve DB path at call time (respects CONTINUITY_DB env override)."""
    return Path(os.environ.get("CONTINUITY_DB", str(_data_dir() / "continuity.db")))


# ── Core interception ──────────────────────────────────────────────────────

import subprocess as _subprocess


def _detect_provider() -> str:
    """Detect git hosting provider from remote URL. Returns 'github' or 'azure'."""
    try:
        proc = _subprocess.run(
            ["git", "remote", "get-url", "origin"],
            capture_output=True, text=True, timeout=5,
        )
        if proc.returncode != 0:
            return "github"
        url = proc.stdout.strip().lower()
        if "dev.azure.com" in url or "visualstudio.com" in url:
            return "azure"
        return "github"
    except Exception:
        return "github"


def _detect_repo(real_gh: str) -> str:
    """Detect current repo as owner/repo via gh CLI."""
    try:
        proc = _subprocess.run(
            [real_gh, "repo", "view", "--json", "nameWithOwner",
             "-q", ".nameWithOwner"],
            capture_output=True, text=True, timeout=10,
        )
        if proc.returncode == 0:
            return proc.stdout.strip()
    except Exception:
        pass
    return ""


def _ensure_repo(db, owner_repo: str) -> None:
    """Auto-register repo if not already tracked."""
    if not owner_repo:
        return
    existing = db.execute(
        "SELECT 1 FROM repos WHERE owner_repo = ?", (owner_repo,)
    ).fetchone()
    if existing:
        return
    owner = owner_repo.split("/")[0] if "/" in owner_repo else owner_repo
    provider = _detect_provider()
    db.execute(
        "INSERT INTO repos (owner_repo, gh_account, provider) VALUES (?, ?, ?)",
        (owner_repo, owner, provider),
    )


def _repo_fn(real_gh: str, db):
    """Returns a callable that lazily detects, caches, and auto-registers
    the current repo. Any parser calling this gets auto-registration for free."""
    cache = ""

    def fn():
        nonlocal cache
        if not cache:
            cache = _detect_repo(real_gh)
            if cache:
                _ensure_repo(db, cache)
        return cache

    return fn


def _ensure_repo_fn(db):
    """Returns a callable for auto-registering repos."""
    def fn(owner_repo: str):
        _ensure_repo(db, owner_repo)
    return fn

def intercept(command: str, args: list[str], real_binary: str,
              db_path: Path, timeout: int = 300) -> int:
    """Core interception logic. Three phases in order:
    1. Block dangerous commands (before delegation)
    2. Delegate to real binary + log raw event
    3. Parse structured CI data from output (post-hoc)
    """
    db = ensure_db(db_path)
    now = int(time.time())

    # Phase 3: dangerous command check — blocks BEFORE delegation
    block_msg = check_dangerous(command, args)
    if block_msg:
        db.execute(
            "INSERT INTO cli_events "
            "(command, args_json, exit_code, duration_ms, blocked, recorded_at) "
            "VALUES (?, ?, -1, 0, 1, ?)",
            (command, json.dumps(args), now),
        )
        db.commit()
        db.close()
        sys.stderr.write(block_msg)
        return 1

    # Provider guard: block gh commands on Azure repos
    if command == "gh":
        provider = _detect_provider()
        if provider == "azure":
            db.execute(
                "INSERT INTO cli_events "
                "(command, args_json, exit_code, duration_ms, blocked, recorded_at) "
                "VALUES (?, ?, -1, 0, 2, ?)",
                (command, json.dumps(args), now),
            )
            db.commit()
            db.close()
            sys.stderr.write(
                "continuity: this repo uses Azure DevOps. Use 'az' CLI instead of 'gh'.\n"
                "Azure DevOps support is not yet implemented.\n"
            )
            return 1

    # Phase 1: delegate + log
    start = time.time()
    proc = run_binary(real_binary, args, timeout=timeout)
    duration_ms = int((time.time() - start) * 1000)

    db.execute(
        "INSERT INTO cli_events "
        "(command, args_json, exit_code, duration_ms, recorded_at) "
        "VALUES (?, ?, ?, ?, ?)",
        (command, json.dumps(args), proc.returncode, duration_ms, int(time.time())),
    )

    # Phase 2: structured parsing (post-hoc, never affects exit code)
    try:
        if command == "gh":
            gh.parse(args, proc.stdout, db, _repo_fn(real_binary, db), _ensure_repo_fn(db))
        elif command == "git":
            git.parse(args, db)
    except Exception:
        pass

    db.commit()
    db.close()

    # Write captured output to real stdout/stderr (transparent pipe)
    sys.stdout.write(proc.stdout)
    sys.stderr.write(proc.stderr)
    return proc.returncode


# ── Entry point ────────────────────────────────────────────────────────────

def main():
    command = os.environ.get("CONTINUITY_COMMAND", "gh")
    real_binary = REAL_GH if command == "gh" else REAL_GIT
    args = sys.argv[1:]
    exit_code = intercept(command, args, real_binary, _resolve_db_path())
    sys.exit(exit_code)


if __name__ == "__main__":
    main()
