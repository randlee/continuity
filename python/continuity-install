#!/usr/bin/env python3
"""continuity install — transparent gh/git interceptors.

Usage:
    python3 continuity-install         # install to ~/.local/bin
    python3 continuity-install --undo  # remove

Sets CONTINUITY_REAL_GH/CONTINUITY_REAL_GIT env vars in wrapper scripts
so the interceptor always delegates to the real binaries.
"""

import os
import shutil
import stat
import sys
from pathlib import Path

BIN_DIR = Path.home() / ".local" / "bin"
POC_DIR = Path(__file__).resolve().parent


def resolve_binary(name: str) -> str:
    """Find the real binary, skipping our own wrappers if already installed."""
    wrapper_path = BIN_DIR / name
    real = shutil.which(name)
    if real and os.path.realpath(real) == str(wrapper_path):
        paths = os.environ.get("PATH", "").split(":")
        for p in paths:
            if p == str(BIN_DIR):
                continue
            candidate = os.path.join(p, name)
            if os.path.isfile(candidate) and os.access(candidate, os.X_OK):
                return candidate
    return real or f"/usr/bin/{name}"


def install():
    BIN_DIR.mkdir(parents=True, exist_ok=True)

    real_gh = resolve_binary("gh")
    real_git = resolve_binary("git")
    print(f"real gh:  {real_gh}")
    print(f"real git: {real_git}")

    interceptor = POC_DIR / "continuity-gh"

    # gh wrapper — sets env vars pointing to real binaries
    gh_path = BIN_DIR / "gh"
    gh_path.write_text(f"""#!/bin/bash
export CONTINUITY_REAL_GH={real_gh}
export CONTINUITY_REAL_GIT={real_git}
exec {sys.executable} {interceptor} "$@"
""")
    gh_path.chmod(gh_path.stat().st_mode | stat.S_IEXEC)
    print(f"✔ {gh_path}")

    # git wrapper — thin shim
    git_path = BIN_DIR / "git"
    git_path.write_text(f"""#!/bin/bash
export CONTINUITY_COMMAND=git
export CONTINUITY_REAL_GH={real_gh}
export CONTINUITY_REAL_GIT={real_git}
exec {sys.executable} {interceptor} "$@"
""")
    git_path.chmod(git_path.stat().st_mode | stat.S_IEXEC)
    print(f"✔ {git_path}")

    print()
    print("export PATH=\"$HOME/.local/bin:$PATH\"")


def uninstall():
    for name in ("gh", "git"):
        p = BIN_DIR / name
        if p.exists():
            p.unlink()
            print(f"✘ {p}")


if __name__ == "__main__":
    uninstall() if "--undo" in sys.argv else install()
